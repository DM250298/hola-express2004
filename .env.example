# ─── Supabase ────────────────────────────────────────────────────────────────
# Encontrás estos valores en: Settings → API de tu proyecto en supabase.com

# URL del proyecto (Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Clave anónima pública (anon / public key)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Clave de service role (solo servidor — para crear usuarios, etc.)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Cron de RRHH (cierre diario de asistencia) ──────────────────────────────
# Secreto que Vercel Cron manda en el header Authorization. Generá uno random
# (ej: openssl rand -hex 32) y cargalo en Vercel → Settings → Environment
# Variables con el MISMO nombre. El cron corre 09:00 UTC (06:00 AR), ver vercel.json.
CRON_SECRET=pegá-acá-un-secreto-random

# ─── Mercado Pago Point (FASE 6 — terminales de cobro) ───────────────────────
# Access Token de producción de tu cuenta de Mercado Pago.
# Se obtiene en: mercadopago.com.ar/developers → Tus integraciones → tu
# aplicación → Credenciales de producción. SOLO servidor, nunca con NEXT_PUBLIC_.
MP_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxx

# ─── Web Push (avisos de producción fuera de la app) ─────────────────────────
# Generá el par de claves UNA vez con:  npx web-push generate-vapid-keys
# Cargá las 3 en Vercel → Environment Variables (la PUBLIC y la PRIVATE también
# en .env.local para probar en dev). La pública es la única con NEXT_PUBLIC_.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VAPID_PRIVATE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Contacto del emisor (lo exige el estándar VAPID). Tu mail con prefijo mailto:
VAPID_SUBJECT=mailto:damianmiranday25@gmail.com
